---
import type { InstagramPost } from '../lib/instagram';

interface Props {
	posts: InstagramPost[];
	profileUrl: string;
	username?: string;
}

const { posts, profileUrl, username = 'earthas_emporium' } = Astro.props;
---

{
	posts.length > 0 ? (
		<div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-6">
			{posts.map((post) => (
				<a
					href={post.permalink}
					target="_blank"
					rel="noopener noreferrer"
					class="group relative aspect-square overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-forest/5"
					aria-label={post.caption ? `View Instagram post: ${post.caption.slice(0, 80)}` : 'View Instagram post'}
				>
					<img
						src={post.mediaUrl}
						alt={post.caption?.slice(0, 120) ?? 'Instagram post from Eartha\'s Emporium'}
						class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
						loading="lazy"
						decoding="async"
					/>
					<div class="absolute inset-0 flex items-center justify-center bg-forest/0 transition-colors group-hover:bg-forest/40">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-10 w-10 text-white opacity-0 transition-opacity group-hover:opacity-100"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
						>
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
						</svg>
					</div>
					{post.mediaType === 'VIDEO' && (
						<span class="absolute right-3 top-3 rounded-full bg-forest/70 px-2 py-1 text-xs font-medium text-white">
							Video
						</span>
					)}
					{post.mediaType === 'CAROUSEL_ALBUM' && (
						<span class="absolute right-3 top-3 rounded-full bg-forest/70 px-2 py-1 text-xs font-medium text-white">
							Album
						</span>
					)}
				</a>
			))}
		</div>
	) : (
		<div class="rounded-2xl bg-white p-10 text-center shadow-sm ring-1 ring-forest/5">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				class="mx-auto h-12 w-12 text-sage"
				viewBox="0 0 24 24"
				fill="currentColor"
				aria-hidden="true"
			>
				<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
			</svg>
			<p class="mt-4 text-lg text-forest/80">
				Follow <span class="font-semibold text-forest">@{username}</span> for the latest plants, market updates, and booth photos.
			</p>
			<a
				href={profileUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-6 inline-block rounded-full bg-teal px-8 py-3 font-semibold text-white transition-colors hover:bg-forest"
			>
				Follow on Instagram
			</a>
		</div>
	)
}

{
	posts.length > 0 && (
		<div class="mt-8 text-center">
			<a
				href={profileUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 font-semibold text-teal transition-colors hover:text-forest"
			>
				<span>See more on @{username}</span>
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	)
}
