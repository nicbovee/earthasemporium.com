---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-forest/10 bg-forest py-12 text-cream">
	<div class="mx-auto max-w-6xl px-6">
		<div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
			<div>
				<Logo variant="horizontal" />
				<p class="mt-4 max-w-sm text-cream/70">
					Curated plants and handmade goods from the heart of the Pikes Peak region.
				</p>
			</div>

			<div class="flex flex-col gap-6 sm:flex-row sm:gap-12">
				<div>
					<p class="text-sm font-semibold uppercase tracking-wider text-cream/50">Visit Us</p>
					<ul class="mt-3 space-y-2 text-sm">
						<li>
							<a href="#markets" class="text-cream/80 transition-colors hover:text-mustard">
								Woodland Park — Fridays
							</a>
						</li>
						<li>
							<a href="#markets" class="text-cream/80 transition-colors hover:text-mustard">
								Old Colorado City — Saturdays
							</a>
						</li>
					</ul>
				</div>

				<div>
					<p class="text-sm font-semibold uppercase tracking-wider text-cream/50">Connect</p>
					<ul class="mt-3 space-y-2 text-sm">
						<li>
							<a
								href="https://www.instagram.com/earthas_emporium/"
								target="_blank"
								rel="noopener noreferrer"
								class="text-cream/80 transition-colors hover:text-mustard"
							>
								Instagram — @earthas_emporium
							</a>
						</li>
						<li>
							<span class="text-cream/50">Facebook — coming soon</span>
						</li>
						<li>
							<span class="text-cream/50">Email — coming soon</span>
						</li>
					</ul>
				</div>
			</div>
		</div>

		<p class="mt-12 border-t border-cream/10 pt-8 text-center text-sm text-cream/50">
			&copy; {year} Eartha's Emporium. All rights reserved.
		</p>
	</div>
</footer>
